# =========================
# 1. Python 编译缓存 (必加)
# =========================
# Python 运行代码时自动生成的缓存文件，毫无保留价值
models/__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# 2. 深度学习专属 (极其重要)
# =========================
# 绝对不能传 PyTorch 的模型权重，动辄几十上百MB！
*.pth
*.pt
*.ckpt

# 绝对不能传数据集文件夹 (CIFAR-10 下载下来接近 200MB)
datasets/
data/

# =========================
# 3. 本地输出的图片与日志
# =========================
# 忽略跑出来的 loss 曲线图、注意力热力图等本地可视化结果
*.jpg
*.jpeg
# 如果你以后用了 tensorboard，忽略它的日志文件
runs/

# =========================
# 4. 操作系统与 IDE 配置文件
# =========================
# 忽略 VS Code 的本地工作区设置
models/.vscode/

# 忽略 Windows 系统自动生成的缩略图缓存
Thumbs.db

# 如果你的同学用 Mac 看你的代码，忽略 Mac 的恶心隐藏文件
.DS_Store